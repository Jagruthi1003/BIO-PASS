# ZK Face Authentication - Development Environment Configuration

# Server Configuration
NODE_ENV=development
PORT=3000
HOST=0.0.0.0

# Logging
LOG_LEVEL=debug
DEBUG=zk-face-auth:*

# CORS Configuration
CORS_ORIGIN=*
CORS_CREDENTIALS=true

# Database (for future use)
# DATABASE_URL=postgresql://user:password@localhost:5432/zk_face_auth

# JWT Configuration (for future use)
# JWT_SECRET=your-secret-key-here
# JWT_EXPIRY=24h

# Circuit Configuration
CIRCUIT_PATH=./zk_circuits
ZKEY_PATH=./zk_circuits/face_verify.zkey
VKEY_PATH=./vkey.json
WASM_PATH=./zk_circuits/face_verify_js/face_verify.wasm

# Security
ENABLE_CORS=true
ENABLE_RATE_LIMITING=false
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX_REQUESTS=100

# Threshold Configuration
DEFAULT_DISTANCE_THRESHOLD=500000000
MIN_DISTANCE_THRESHOLD=100000000
MAX_DISTANCE_THRESHOLD=1000000000

# Development
AUTO_RELOAD=true
MOCK_PROOFS=false
VERBOSE_LOGGING=true
