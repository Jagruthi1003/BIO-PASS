# Firebase Cloud Functions Configuration
# Used for sending OTP emails

# Option 1: Gmail Configuration
# 1. Enable 2-Factor Authentication on your Gmail account
# 2. Generate an App Password: https://myaccount.google.com/apppasswords
# 3. Use the 16-character password below

EMAIL_USER=your-email@gmail.com
EMAIL_PASSWORD=your-16-character-app-password

# Option 2: SendGrid Configuration
# 1. Get API key from https://app.sendgrid.com/settings/api_keys
# 2. Create a sender email verified in SendGrid

SENDGRID_API_KEY=SG.your-sendgrid-api-key
SENDGRID_FROM_EMAIL=noreply@biopass.pondiuni.ac.in

# Option 3: Custom SMTP (if using your own email server)
SMTP_HOST=smtp.yourserver.com
SMTP_PORT=587
SMTP_USER=your-username
SMTP_PASSWORD=your-password

# Application Settings
NODE_ENV=production
LOG_LEVEL=info
